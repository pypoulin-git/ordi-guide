# ─────────────────────────────────────────────────────
# Shop Compy — Variables d'environnement
# Copier ce fichier vers .env.local et remplir les valeurs
# ─────────────────────────────────────────────────────

# ── Site ──────────────────────────────────────────────
# URL canonique du site (override le défaut https://shopcompy.ca)
# NEXT_PUBLIC_SITE_URL=https://shopcompy.ca

# ── AI (requis pour la recherche et le blog) ──────────
GOOGLE_API_KEY=

# ── Affiliés ──────────────────────────────────────────
# Amazon Associates Canada — https://associates.amazon.ca
NEXT_PUBLIC_AMAZON_TAG=shopcompy-20

# Newegg via Rakuten — https://rakutenadvertising.com
NEXT_PUBLIC_NEWEGG_AFF=

# Best Buy CA via Impact — https://impact.com
# Note: 0% commission sur ordis/tablettes, utile pour accessoires seulement
NEXT_PUBLIC_BESTBUY_REF=

# Bureau en Gros / Staples — programme direct
NEXT_PUBLIC_STAPLES_ID=

# Lenovo Canada — programme affilié direct
NEXT_PUBLIC_LENOVO_AFF=

# Dell Canada — programme affilié direct
NEXT_PUBLIC_DELL_AFF=

# HP Canada — programme affilié direct
NEXT_PUBLIC_HP_AFF=

# Walmart Canada via Rakuten
NEXT_PUBLIC_WALMART_AFF=

# Canada Computers — programme direct
NEXT_PUBLIC_CC_AFF=

# ── Publicité ─────────────────────────────────────────
# Google AdSense — https://adsense.google.com
# Laisser vide = aucune pub chargée (safe pour dev/preview)
NEXT_PUBLIC_ADSENSE_ID=

# ── Paiements (Stripe) ───────────────────────────────
# Stripe Payment Links — créer dans https://dashboard.stripe.com
# Support expert — lien unique
NEXT_PUBLIC_STRIPE_SUPPORT_URL=https://buy.stripe.com/3cIaEQaRb3x9dFZ0Y32Ry01

# Don volontaire (Trouvailles Compy) — lien unique montant variable
NEXT_PUBLIC_STRIPE_DONATION_URL=https://donate.stripe.com/7sY8wI9N79Vx45pdKP2Ry00
